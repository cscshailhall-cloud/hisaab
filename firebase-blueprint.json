{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "A customer of the CSC center",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the customer" },
        "mobile": { "type": "string", "description": "Mobile number for WhatsApp and contact" },
        "email": { "type": "string", "description": "Email address" },
        "address": { "type": "string", "description": "Physical address" },
        "outstanding": { "type": "number", "description": "Total unpaid balance" },
        "totalSpent": { "type": "number", "description": "Total amount invoiced" },
        "totalPaid": { "type": "number", "description": "Total amount paid" },
        "billsCount": { "type": "number", "description": "Number of invoices generated" },
        "lastVisit": { "type": "string", "format": "date-time", "description": "Last time the customer visited" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "mobile"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice generated for a customer",
      "type": "object",
      "properties": {
        "invoiceNo": { "type": "string", "description": "Unique invoice number" },
        "customerId": { "type": "string", "description": "ID of the customer" },
        "customerName": { "type": "string", "description": "Name of the customer at time of billing" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Paid", "Pending", "Overdue"] },
        "method": { "type": "string", "description": "Payment method (Cash, UPI, Card, etc.)" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "tax": { "type": "number" }
            }
          }
        },
        "discount": { "type": "number" },
        "taxAmount": { "type": "number" },
        "subtotal": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNo", "customerId", "amount", "status"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the CSC center",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application settings and business profile",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "businessAddress": { "type": "string" },
        "businessMobile": { "type": "string" },
        "businessEmail": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "ifscCode": { "type": "string" },
        "accountHolder": { "type": "string" },
        "terms": { "type": "string" },
        "defaultTemplate": { "type": "string" },
        "accentColor": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/customers": { "schema": "Customer", "description": "Collection of customers" },
    "/invoices": { "schema": "Invoice", "description": "Collection of invoices" },
    "/services": { "schema": "Service", "description": "Collection of services" },
    "/settings/global": { "schema": "Settings", "description": "Global application settings" }
  }
}
